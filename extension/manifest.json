{
  "manifest_version": 3,
  "name": "Repo Talk - GitHub Collaboration Chat",
  "version": "1.0.0",
  "description": "Real-time chat for GitHub repositories, pull requests, and issues",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "host_permissions": [
    "https://github.com/*",
    "https://www.github.com/*",
    "http://localhost:*/*",
    "https://*.clerk.accounts.dev/*",
    "https://*.lcl.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://www.github.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Repo Talk - GitHub Chat"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html"],
      "matches": ["https://github.com/*", "https://www.github.com/*"]
    }
  ]
}
